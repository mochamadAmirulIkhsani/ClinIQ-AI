# NODE ENV
NODE_ENV=local

# CORS Configuration
# Use * only for local development.
ALLOWED_ORIGINS=*

# DB (PostgreSQL)
DB_USER=postgres
DB_PASS=change-me-local-db-password
DB_NAME=cliniq_ai
DB_HOST=127.0.0.1
DB_PORT=5433
DB_CONNECTION=postgres
DB_SSL=false

# REDIS
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change-me-local-redis-password

# S3
AWS_ACCESS_KEY_ID=put-your-access-key-id-here
AWS_SECRET_ACCESS_KEY=put-your-secret-access-key-here
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=put-your-bucket-name-here
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=

# JWT
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# AI
AI_BASE_URL=http://localhost:20128/v1
AI_API_KEY=put-your-api-key-here
AI_MODEL=put-your-model-here
AI_SITE_URL=https://cliniq-ai.local
AI_SITE_NAME=ClinIQ-AI
AI_REQUEST_TIMEOUT_MS=60000